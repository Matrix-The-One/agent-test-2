{
  "name": "@agent/server",
  "private": true,
  "type": "module",
  "scripts": {
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "openapi:export": "pnpm run prisma:generate && tsx src/openApiExport.ts",
    "build": "pnpm run prisma:generate && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "dev": "tsx watch src/main.ts",
    "lint": "pnpm run prisma:generate && tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm run prisma:generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/langchain": "^2.0.174",
    "@langchain/core": "^1.0.6",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/openai": "^1.4.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "ai": "^6.0.168",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.5",
    "js-tiktoken": "^1.0.21",
    "langchain": "^1.3.3",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "prisma": "^7.7.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
